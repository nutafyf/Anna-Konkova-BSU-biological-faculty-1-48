# 1. даем рабу системы ввести данные и сразу разбиваем через пробел, превраща в список
data = input("Введите n и k через пробел: ").split()

# 2. превращаем по очереди два кусочка в целые числа
n = int(data[0])
k = int(data[1])

# 3. ПРОВЕРКА (если n больше 40 ИЛИ k больше 5)
if n > 40 or k > 5:
    # Если условие верно, просто пишем ошибку и всё
    print("Ошибка: n не должно быть > 40, а k не должно быть > 5")
else:
    # ИНАЧЕ (если всё правильно), выполняем решение задачи
    
    # Создаем список с первыми двумя месяцами (всегда 1 и 1)
    rabbits = [1, 1]
    
    # Если просят 1 или 2 месяц — ответ сразу 1
    if n == 1 or n == 2:
        print(1)
    else:
        # Считаем с 3-го месяца до n
        for month in range(2, n):
            # Формула: (прошлый месяц) + (k * кролики, ставшие родителями)
            new_generation = rabbits[month - 1] + k * rabbits[month - 2]
            # Добавляем результат в список
            rabbits.append(new_generation)
        
        # Печатаем самый последний элемент из списка
        print(rabbits[-1])