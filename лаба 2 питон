import os
import psutil
import random
import tempfile


def find_processes(file_path):
    abs_path = os.path.abspath(file_path)
    procs = []
    for proc in psutil.process_iter(["pid", "name"]):
        try:
            for item in proc.open_files() or []:
                if item.path == abs_path:
                    procs.append(
                        f"{proc.info['name']} (Идентификатор процесса: {proc.info['pid']})"
                    )
        except (psutil.NoSuchProcess, psutil.AccessDenied):
            continue
    return procs


def secure_atomic_overwrite(file_path, data):
    if os.path.exists(file_path):
        procs = find_processes(file_path)
        if procs:
            print(
                f"ВНИМАНИЕ: Файл заблокирован другими приложениями: {', '.join(procs)}"
            )
            return False

    parent_dir = os.path.dirname(os.path.abspath(file_path))
    fd, temp_path = tempfile.mkstemp(dir=parent_dir, text=True)

    try:
        with os.fdopen(fd, "w", encoding="utf-8") as temp_file:
            temp_file.write(data)
            temp_file.flush()
            os.fsync(temp_file.fileno())

        os.replace(temp_path, file_path)
        print("Запись завершена. Файл успешно обновлен.")
        return True

    except Exception as e:
        print(f"Произошел системный сбой: {e}")
        if os.path.exists(temp_path):
            os.remove(temp_path)
        return False


